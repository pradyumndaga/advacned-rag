# OpenAI API key — used for chat/completion (mini + main tier) and embeddings.
OPENAI_API_KEY=

# Redis connection string — used by BullMQ for the ingestion queue.
# Local: redis://localhost:6379 (also the default if this is left empty)
# Redis Cloud: redis://default:<password>@<host>:<port>
REDIS_URL=

# Qdrant Cloud API key.
QDRANT_API_KEY=

# Qdrant Cloud cluster URL, e.g. https://xxxxxxxx.qdrant.io:6333
QDRANT_DB=

# Optional — Qdrant collection name for indexed chunks. Defaults to
# "advanced-rag-chunks" if unset; the collection is created automatically
# on first use.
# QDRANT_COLLECTION=

# Clerk authentication — create a free application at https://clerk.com,
# then copy these from your Clerk dashboard's API Keys page (or run
# `clerk init --app <your-app-id>` after `clerk auth login`, which writes
# them here automatically).
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/
